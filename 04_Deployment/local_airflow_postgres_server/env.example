# Airflow web UI credentials
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow 

# ── Airflow metadata database (PostgreSQL) ─
POSTGRES_AIRFLOW_USER=airflow
POSTGRES_AIRFLOW_PASSWORD=airflow 
POSTGRES_AIRFLOW_DB=airflow

# ── CitiBike operational database ──────────
POSTGRES_DATA_USER=citibike
POSTGRES_DATA_PASSWORD=citibike  
POSTGRES_DATA_DB=citibike_db

# ── Evidently Cloud (drift monitoring) ─────
EVIDENTLY_CLOUD_TOKEN=your_evidently_token_here
EVIDENTLY_CLOUD_PROJECT_ID=your_project_id_here

# ── AWS S3 (historical data archive) ───────
AWS_ACCESS_KEY_ID=your_aws_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_here

# ── S3 bucket ──────────────────────────────
AIRFLOW_VAR_S3_BUCKET=your-s3-bucket-name

# ── External APIs ──────────────────────────
RAPIDAPI_KEY=your_rapidapi_key_here            # https://rapidapi.com


# ── MinIO (MLflow artifact store) ──────────
# Used by Airflow to communicate with the MLflow stack
AIRFLOW_VAR_MLFLOW_TRACKING_INTERNAL_URI=http://host.docker.internal:5001
AIRFLOW_VAR_MLFLOW_S3_ENDPOINT_INTERNAL_URL=http://host.docker.internal:9000
AIRFLOW_VAR_MINIO_ACCESS_KEY_ID=minioadmin
AIRFLOW_VAR_MINIO_AWS_SECRET_ACCESS_KEY=minioadmin

# ── External APIs ──────────────────────────
RAPIDAPI_KEY=your_rapidapi_key_here            # https://rapidapi.com